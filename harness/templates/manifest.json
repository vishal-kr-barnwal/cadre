{
  "templates": [
    {
      "id": "product",
      "source": "product.json",
      "target": "cadre/product.json",
      "projection": "cadre/product.md",
      "purpose": "Product summary, users, workflows, domain model, invariants, architecture boundaries, data ownership, and release expectations.",
      "scope": "target-project"
    },
    {
      "id": "workflow",
      "source": "workflow.json",
      "target": "cadre/workflow.json",
      "projection": "cadre/workflow.md",
      "purpose": "Project development, verification, review, and commit expectations.",
      "scope": "target-project"
    },
    {
      "id": "product-guidelines",
      "source": "product_guidelines.json",
      "target": "cadre/product_guidelines.json",
      "projection": "cadre/product_guidelines.md",
      "purpose": "Product principles, user promises, non-goals, and decision rules reviewed during setup.",
      "scope": "target-project"
    },
    {
      "id": "patterns",
      "source": "patterns_seed.json",
      "target": "cadre/patterns.jsonl",
      "projection": "cadre/patterns.md",
      "purpose": "Reusable codebase patterns and completed-track learnings.",
      "scope": "target-project"
    },
    {
      "id": "learnings",
      "source": "learnings_seed.json",
      "target": "cadre/tracks/<track_id>/learnings.jsonl",
      "projection": "cadre/tracks/<track_id>/learnings.md",
      "purpose": "Per-track learning journal starter.",
      "scope": "target-project"
    },
    {
      "id": "config",
      "source": "config.json",
      "target": "cadre/config.json",
      "purpose": "Cadre sync, provider, review, and quality defaults.",
      "scope": "target-project"
    },
    {
      "id": "repos",
      "source": "repos.json",
      "target": "cadre/repos.json",
      "purpose": "Polyrepo topology starter.",
      "scope": "target-project"
    },
    {
      "id": "style-guides",
      "source": "styleguides/*.json",
      "target": "cadre/styleguides/*.json",
      "projection": "cadre/code_styleguides/*.md",
      "purpose": "Language-specific implementation guidance selected by setup packets.",
      "scope": "target-project"
    },
    {
      "id": "target-monorepo-ci",
      "source": "ci/cadre-monorepo-check.github.yml",
      "target": ".github/workflows/cadre-monorepo-check.yml",
      "purpose": "Cadre target-project drift and review gate for GitHub monorepos.",
      "scope": "target-project"
    },
    {
      "id": "target-monorepo-ci-gitlab",
      "source": "ci/cadre-monorepo-check.gitlab.yml",
      "target": ".gitlab-ci.yml",
      "purpose": "Cadre target-project drift and review gate for GitLab monorepos.",
      "scope": "target-project"
    },
    {
      "id": "polyrepo-merge-train-github",
      "source": "ci/cadre-merge-train.github.yml",
      "target": ".github/workflows/cadre-merge-train.yml",
      "purpose": "Cross-repo merge train for GitHub polyrepo control repositories.",
      "scope": "target-project"
    },
    {
      "id": "polyrepo-merge-train-gitlab",
      "source": "ci/cadre-merge-train.gitlab.yml",
      "target": ".gitlab-ci.yml",
      "purpose": "Cross-repo merge train for GitLab polyrepo control repositories.",
      "scope": "target-project"
    }
  ]
}
